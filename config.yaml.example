# 网络小说生成器配置模板
# 复制此文件为 config.yaml 并填入实际值

# DeepSeek API 配置
llm:
  api_key: "your-deepseek-api-key"
  base_url: "https://api.deepseek.com"
  model: "deepseek-chat"  # 或 deepseek-reasoner
  max_tokens: 16384  # 输出上限（非上下文），6000字章节约需8000-12000 tokens
  temperature: 0.8

# 生成参数默认值
generation:
  words_per_chapter: 5000        # 每章默认字数 (4000-6000)
  chapters_per_volume: 50        # 每卷默认章数 (可自行修改)
  generation_mode: "continuous"  # 生成模式: single(逐章), batch(批量), continuous(连续对话)
  batch_size: 3                  # batch模式下每次LLM调用生成章节数
  round_size: 10                 # continuous模式下每轮章节数
  target_total_words: 2000000    # 目标总字数

# 审计参数
audit:
  enabled: true
  auto_fix: false              # 是否自动修复（true=自动，false=输出报告人工确认）
  logic_severity_threshold: "minor"  # 报告的最低严重级别: critical, major, minor
